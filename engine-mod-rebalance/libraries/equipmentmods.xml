  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/@max">1.45</replace><!-- vanilla 1.45 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/bonus/travelthrust/@min">0.85</replace><!-- vanilla 0.7 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/bonus/travelthrust/@max">0.85</replace><!-- vanilla 0.75 -->


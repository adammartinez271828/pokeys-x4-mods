       boost-accel too (Nudger reaches 1.35), so this must clear 1.35 to own
       the stat. -->
  <replace sel="/equipmentmods/engine/boostacc[@ware='mod_engine_travelstartthrust_01_mk1']/@min">1.45</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/engine/boostacc[@ware='mod_engine_travelstartthrust_01_mk1']/@max">1.45</replace><!-- vanilla 1.2 -->

  <!-- Spur = TRAVEL ATTACK (spool-up) specialist. Lower time = faster into
       travel; forward thrust cannot buy spool-up. -->
  <replace sel="/equipmentmods/engine/travelattacktime[@ware='mod_engine_travelattacktime_01_mk1']/@min">0.75</replace><!-- vanilla 0.8 -->
  <replace sel="/equipmentmods/engine/travelattacktime[@ware='mod_engine_travelattacktime_01_mk1']/@max">0.75</replace><!-- vanilla 0.95 -->

  <!-- Overdrive = TRAVEL CHARGE (spool-up) specialist. -->
  <replace sel="/equipmentmods/engine/travelchargetime[@ware='mod_engine_travelchargetime_01_mk1']/@min">0.75</replace><!-- vanilla 0.8 -->
  <replace sel="/equipmentmods/engine/travelchargetime[@ware='mod_engine_travelchargetime_01_mk1']/@max">0.75</replace><!-- vanilla 0.95 -->

  <!-- Anchor = STRAFE-ACCEL specialist (+30%). Quick sideways response;
       distinct from Crab/Sidewinder which raise strafe top speed. -->
  <replace sel="/equipmentmods/engine/strafeacc[@ware='mod_engine_travelreleasetime_01_mk1']/@min">1.3</replace><!-- vanilla 1.1 -->
  <replace sel="/equipmentmods/engine/strafeacc[@ware='mod_engine_travelreleasetime_01_mk1']/@max">1.3</replace><!-- vanilla 1.3 -->

  <!-- Spinner = clean ROTATION (+25%, no downside). Agility is un-leakable,

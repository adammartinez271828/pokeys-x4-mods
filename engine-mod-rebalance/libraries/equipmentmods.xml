  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk1']/@max">1.25</replace><!-- vanilla 1.2 -->

  <!-- Crab = clean STRAFE (+25%, no downside). -->

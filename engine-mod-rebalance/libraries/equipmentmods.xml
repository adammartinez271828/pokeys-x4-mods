<?xml version="1.0" encoding="utf-8"?>
<!-- Pokey's Engine Mod Rebalance - engine section of equipmentmods.xml only.

     Design: docs/engine-mod-rebalance-design.md.
     Validate: tools/engine-mod-rebalance/evaluate.py (exit 0 = E1-E4 pass;
     the harness applies this diff itself, so a sel typo is a hard error).

     ARCHETYPE MODEL. Each tier offers FOUR clear archetypes, one carrier mod
     each (chosen for what the mod's NAME evokes, with riders added to fill
     out the identity); every other mod is parked at a token "degenerate"
     value - present but plainly not the pick, so the tier has a small set of
     real choices instead of a crowded field.

       Archetype    Feel                Basic / Enhanced / Exceptional carrier
       Interceptor  straight-line speed Nudger / Impeller / Slingshot
       Dogfighter   turn + strafe       Sidewinder / Antares / Whirlygig
       Booster      boost burst         Afterburner / Delta / Atlas
       Voyager      travel + spool-up   Overdrive / Vinci / Vikas

     - forwardthrust also drives boost AND travel speed, so the Interceptor
       is a BROAD lever: it is pinned modestly (Basic +10%) precisely because
       that +10% lands on four stats at once. The specialists get bigger
       single-axis numbers.
     - No RNG (every range pinned min = max). No maluses (archetypes are pure
       upside; the old fake forward-thrust "penalties" are removed).
     - Tiered floor keeps the power curve monotonic: the weakest mod pays
       +5% (Basic), +10% (Enhanced), and the Exceptional tier is all
       archetypes (>= +20%). Carriers scale above their tier's floor.
     Scenario mods (*_transport_refugees, *_escort_scenario) are untouched. -->
<diff>

  <!-- ============================ BASIC (quality 1) ==================== -->
  <!-- Carriers ~+10-20%; degenerate = +5% (times x0.95). -->

  <!-- INTERCEPTOR = Nudger. +10% forward thrust = +10% forward, boost,
       travel and boost-accel at once (the broad-lever discount). Vanilla's
       fake boost/travel malus is removed. -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/@min">1.1</replace><!-- vanilla 1.35 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/@max">1.1</replace><!-- vanilla 1.45 -->
  <remove sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/bonus"/><!-- drop fake boost/travel malus -->

  <!-- DOGFIGHTER = Sidewinder. Strafe + turning. Vanilla rotation malus
       becomes a rotation buff. -->
  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_02_mk1']/@min">1.2</replace><!-- vanilla 1.35 -->
  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_02_mk1']/@max">1.2</replace><!-- vanilla 1.45 -->
  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_02_mk1']/bonus/rotationthrust/@min">1.18</replace><!-- vanilla 0.7 malus -> buff -->
  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_02_mk1']/bonus/rotationthrust/@max">1.18</replace><!-- vanilla 0.75 -->

  <!-- BOOSTER = Afterburner. Boost accel + boost speed + duration. Riders
       added (vanilla has none). -->
  <replace sel="/equipmentmods/engine/boostacc[@ware='mod_engine_travelstartthrust_01_mk1']/@min">1.2</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/engine/boostacc[@ware='mod_engine_travelstartthrust_01_mk1']/@max">1.2</replace><!-- vanilla 1.2 -->
  <add sel="/equipmentmods/engine/boostacc[@ware='mod_engine_travelstartthrust_01_mk1']"><bonus chance="1.0" max="2"><boostthrust min="1.2" max="1.2"/><boostduration min="1.15" max="1.15"/></bonus></add>

  <!-- VOYAGER = Overdrive. Fast travel spool + travel speed. Riders added. -->
  <replace sel="/equipmentmods/engine/travelchargetime[@ware='mod_engine_travelchargetime_01_mk1']/@min">0.8</replace><!-- vanilla 0.8 -->
  <replace sel="/equipmentmods/engine/travelchargetime[@ware='mod_engine_travelchargetime_01_mk1']/@max">0.8</replace><!-- vanilla 0.95 -->
  <add sel="/equipmentmods/engine/travelchargetime[@ware='mod_engine_travelchargetime_01_mk1']"><bonus chance="1.0" max="2"><travelthrust min="1.2" max="1.2"/><travelattacktime min="0.82" max="0.82"/></bonus></add>

  <!-- ---- Basic degenerate (parked at +5%, times x0.95) ---- -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk1']/@min">1.05</replace><!-- Pusher -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk1']/@min">1.05</replace><!-- Juno -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/boostduration[@ware='mod_engine_boostduration_01_mk1']/@min">1.05</replace><!-- Creatine -->
  <replace sel="/equipmentmods/engine/boostduration[@ware='mod_engine_boostduration_01_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk1']/@min">1.05</replace><!-- Aestus -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/travelattacktime[@ware='mod_engine_travelattacktime_01_mk1']/@min">0.95</replace><!-- Spur -->
  <replace sel="/equipmentmods/engine/travelattacktime[@ware='mod_engine_travelattacktime_01_mk1']/@max">0.95</replace>
  <replace sel="/equipmentmods/engine/strafeacc[@ware='mod_engine_travelreleasetime_01_mk1']/@min">1.05</replace><!-- Anchor -->
  <replace sel="/equipmentmods/engine/strafeacc[@ware='mod_engine_travelreleasetime_01_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk1']/@min">1.05</replace><!-- Spinner -->
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_01_mk1']/@min">1.05</replace><!-- Crab -->
  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_01_mk1']/@max">1.05</replace>
  <!-- Twister/Minuteman/Reaver were the vanilla _02 "strong" mods; park them
       at +5% and neutralise their malus riders to 1.0 (no effect). -->
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_02_mk1']/@min">1.05</replace><!-- Twister -->
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_02_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_02_mk1']/bonus/strafethrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_02_mk1']/bonus/strafethrust/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/@min">1.05</replace><!-- Minuteman -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/bonus/travelthrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk1']/bonus/travelthrust/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk1']/@min">1.05</replace><!-- Reaver -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk1']/@max">1.05</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk1']/bonus/boostthrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk1']/bonus/boostthrust/@max">1.0</replace>

  <!-- ========================= ENHANCED (quality 2) =================== -->
  <!-- Carriers ~+20-30%; degenerate = +10% (the tier floor). -->

  <!-- INTERCEPTOR = Impeller. +20% forward (leaks to boost/travel). Fake
       malus removed. -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk2']/@min">1.2</replace><!-- vanilla 1.2 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk2']/@max">1.2</replace><!-- vanilla 1.25 -->
  <remove sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk2']/bonus"/>

  <!-- DOGFIGHTER = Antares. No rotation/strafe WARE exists at q2, so the
       boost mod is repurposed into the agility carrier: boost pinned to a
       token, turn + strafe riders replace the vanilla pool. -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/@min">1.05</replace><!-- vanilla 1.1 (token) -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/@max">1.05</replace><!-- vanilla 1.2 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus/@max">3</replace>
  <remove sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus/boostduration"/>
  <remove sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus/boostacc"/>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus/strafethrust/@min">1.2</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus/strafethrust/@max">1.2</replace>
  <add sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus"><rotationthrust min="1.2" max="1.2"/></add><!-- 1.25 trimmed to offset the fwd rider -->
  <add sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk2']/bonus"><forwardthrust min="1.075" max="1.075"/></add><!-- +7.5% speed vs Basic -->


  <!-- BOOSTER = Delta. +30% boost + duration rider (vanilla travel malus
       swapped for the buff). -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk2']/@min">1.25</replace><!-- vanilla 1.2; 1.30 trimmed to offset fwd rider -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk2']/@max">1.25</replace><!-- vanilla 1.25 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk2']/bonus/@max">2</replace>
  <remove sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk2']/bonus/travelthrust"/>
  <add sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk2']/bonus"><boostduration min="1.2" max="1.2"/></add>
  <add sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_02_mk2']/bonus"><forwardthrust min="1.075" max="1.075"/></add><!-- +7.5% speed vs Basic -->


  <!-- VOYAGER = Vinci. +30% travel + fast spool riders (vanilla boost malus
       swapped for spool). -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/@min">1.25</replace><!-- vanilla 1.2; 1.30 trimmed to offset fwd rider -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/@max">1.25</replace><!-- vanilla 1.25 -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/bonus/@max">3</replace>
  <remove sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/bonus/boostthrust"/>
  <add sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/bonus"><travelchargetime min="0.8" max="0.8"/></add>
  <add sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/bonus"><travelattacktime min="0.82" max="0.82"/></add>
  <add sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_02_mk2']/bonus"><forwardthrust min="1.075" max="1.075"/></add><!-- +7.5% speed vs Basic -->


  <!-- ---- Enhanced degenerate (parked at +10%, pools neutralised to 1.0) ---- -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk2']/@min">1.1</replace><!-- Propeller -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk2']/@max">1.1</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk2']/bonus/rotationthrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk2']/bonus/rotationthrust/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk2']/bonus/strafethrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk2']/bonus/strafethrust/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/@min">1.1</replace><!-- Mira -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/@max">1.1</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/travelstartthrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/travelstartthrust/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/travelattacktime/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/travelattacktime/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/travelchargetime/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/travelchargetime/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/rotationthrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/rotationthrust/@max">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/strafethrust/@min">1.0</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk2']/bonus/strafethrust/@max">1.0</replace>

  <!-- ======================= EXCEPTIONAL (quality 3) ================== -->
  <!-- Four archetype capstones (all mods here are carriers). Pinned; rich
       forced buff sets, no maluses, primaries >= +20%. -->

  <!-- INTERCEPTOR = Slingshot: +30% forward + boost/travel/turn/strafe. -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/@min">1.3</replace><!-- vanilla 1.1 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/@max">1.3</replace><!-- vanilla 1.3 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/boostthrust/@min">1.2</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/boostthrust/@max">1.2</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/travelthrust/@min">1.2</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/travelthrust/@max">1.2</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/rotationthrust/@min">1.15</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/rotationthrust/@max">1.15</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/strafeacc/@min">1.2</replace>
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk3']/bonus/strafeacc/@max">1.2</replace>

  <!-- DOGFIGHTER = Whirlygig: +40% turn + forward + strafe. -->
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk3']/@min">1.4</replace><!-- vanilla 1.2 -->
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk3']/@max">1.4</replace><!-- vanilla 1.5 -->
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk3']/bonus/forwardthrust/@min">1.15</replace>
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk3']/bonus/forwardthrust/@max">1.15</replace>
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk3']/bonus/strafethrust/@min">1.3</replace>
  <replace sel="/equipmentmods/engine/rotationthrust[@ware='mod_engine_rotationthrust_01_mk3']/bonus/strafethrust/@max">1.3</replace>

  <!-- BOOSTER = Atlas: +50% boost + forward + duration + accel + strafe. Must
       clearly out-boost Slingshot, whose forward leak x boost rider reaches
       ~1.56 boost speed; +50% boost x its 1.15 forward rider = ~1.73. -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/@min">1.5</replace><!-- vanilla 1.1 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/@max">1.5</replace><!-- vanilla 1.3 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/forwardthrust/@min">1.15</replace>

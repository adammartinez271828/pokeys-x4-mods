  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/boostduration/@min">1.3</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/boostduration/@max">1.3</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/boostacc/@min">1.25</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/boostacc/@max">1.25</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/strafethrust/@min">1.2</replace>
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk3']/bonus/strafethrust/@max">1.2</replace>

  <!-- VOYAGER = Vikas: +50% travel + forward + start-thrust + fast spool +
       turn + strafe. Must clearly out-travel Slingshot's ~1.56 leaked travel
       speed; +50% travel x its 1.15 forward rider = ~1.73. -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/@min">1.5</replace><!-- vanilla 1.1 -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/@max">1.5</replace><!-- vanilla 1.3 -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/forwardthrust/@min">1.15</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/forwardthrust/@max">1.15</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/travelstartthrust/@min">1.25</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/travelstartthrust/@max">1.25</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/travelattacktime/@min">0.78</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/travelattacktime/@max">0.78</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/travelchargetime/@min">0.78</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/travelchargetime/@max">0.78</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/rotationthrust/@min">1.15</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/rotationthrust/@max">1.15</replace>
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk3']/bonus/strafethrust/@min">1.15</replace>

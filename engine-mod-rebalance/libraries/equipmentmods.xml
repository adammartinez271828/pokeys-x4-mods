<?xml version="1.0" encoding="utf-8"?>
<!-- Pokey's Engine Mod Rebalance - engine section of equipmentmods.xml only.

     Design: docs/engine-mod-rebalance-design.md (fork A - forward thrust
     stays the straight-line king; rivals win on stats it physically can't
     buy: turn, strafe, boost duration, travel spool-up).
     Validate: tools/engine-mod-rebalance/evaluate.py (exit 0 = E1-E4 pass;
     the harness applies this diff itself, so a sel typo is a hard error).

     THE MODEL (all ranges pinned min = max - no RNG):
     - forwardthrust feeds forward speed AND (as a multiplier of forward
       thrust) boost speed, travel speed and boost-accel. So a forward mod is
       a GENERALIST: it moves four stats at once. Its cost, if any, is charged
       in AGILITY (turn), the one currency the leak cannot refund.
     - Every specialist (_02) buffs its axis ABOVE the forward generalist's
       leak and pays an HONEST malus in a stat its own buff cannot refund.
     - Every clean single-axis mod (_01) sits just above the generalist leak,
       so it stays a valid "no-downside" pick (it wins the stat the matching
       _02 sacrificed).
     - The five utility mods own stats forward thrust never touches
       (boost duration, boost-accel, strafe-accel, travel charge/attack).
     Scenario mods (*_transport_refugees, *_escort_scenario) are
     availability-gated and left untouched. -->
<diff>

  <!-- ============================ BASIC (quality 1) ==================== -->

  <!-- Pusher = FORWARD GENERALIST. +20% forward thrust leaks +20% to boost,
       travel and boost-accel: the universal "faster everywhere" pick, the
       benchmark the specialists must beat on their own axis. -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk1']/@min">1.2</replace><!-- vanilla 1.025 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_01_mk1']/@max">1.2</replace><!-- vanilla 1.1 -->

  <!-- Juno = clean BOOST (+25%, no downside). Just above the generalist's
       +20% boost leak, so it is never a strictly worse Pusher. -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk1']/@min">1.25</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/engine/boostthrust[@ware='mod_engine_boostthrust_01_mk1']/@max">1.25</replace><!-- vanilla 1.2 -->

  <!-- Creatine = BOOST DURATION specialist (+30%). Forward thrust cannot buy
       duration, so this is an un-contested niche. -->
  <replace sel="/equipmentmods/engine/boostduration[@ware='mod_engine_boostduration_01_mk1']/@min">1.3</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/engine/boostduration[@ware='mod_engine_boostduration_01_mk1']/@max">1.3</replace><!-- vanilla 1.2 -->

  <!-- Aestus = clean TRAVEL (+25%, no downside), just above the generalist
       travel leak. -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk1']/@min">1.25</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/engine/travelthrust[@ware='mod_engine_travelthrust_01_mk1']/@max">1.25</replace><!-- vanilla 1.2 -->


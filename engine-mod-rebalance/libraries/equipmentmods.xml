  <replace sel="/equipmentmods/engine/strafethrust[@ware='mod_engine_strafethrust_01_mk1']/@max">1.25</replace><!-- vanilla 1.2 -->

  <!-- Nudger = FORWARD SPECIALIST (+35%, leaks +35% to boost/travel/boost-
       accel) paying an HONEST -15% turn. Vanilla charged this in boost+travel
       - which forward thrust silently refunds - so we swap that fake malus
       for a real agility cost: remove the boost/travel maluses, add a turn
       malus, collapse the bonus to one child. -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/@min">1.35</replace><!-- vanilla 1.35 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/@max">1.35</replace><!-- vanilla 1.45 -->
  <replace sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/bonus/@max">1</replace><!-- vanilla 2 -->
  <remove sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/bonus/boostthrust"/><!-- fake malus (leak refunds it) -->
  <remove sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/bonus/travelthrust"/><!-- fake malus (leak refunds it) -->
  <add sel="/equipmentmods/engine/forwardthrust[@ware='mod_engine_forwardthrust_02_mk1']/bonus"><rotationthrust min="0.85" max="0.85"/></add><!-- honest agility cost -->


<!-- Pokey's Weapon Mod Rebalance - weapon section of equipmentmods.xml only.

     Design (docs/weapon-mod-rebalance-design.md, scorecard in
     docs/weapon-mod-rebalance-v1.md):
     - NO RNG: every roll range is pinned (min = max) - what you craft is
       what you get, rerolling is pointless.
     - BASIC TIER = the seven non-empty COMBINATIONS of the three DPS
       stats (damage, cooling, reload), one per mod, so every mod has a
       legible identity and no two share an effect set:
         Piercer     damage
         Cowboy      reload
         Tramontane  cooling
         Gregale     damage + cooling
         Stabber     damage + reload
         Mistral     cooling + reload
         Slasher     damage + cooling + reload
       Values below are SANITY STARTERS meant for tuning in the slider
       tool (tools/weapon-mod-rebalance/tuner.html), NOT final balance.
       Effects a mod's combo excludes are pinned to 1.0 in its (data-fixed)
       bonus slots. Enhanced/Exceptional keep interim pinned values until
       the Basic identities settle.
     - Secondary bundles stay worth <25% cycle DPS on any weapon (a mod's
       secondaries are part of its combo identity, so this cap sits near
       the strongest single-stat mod's headline, not the old 16%).
     - Structural malus slots that no longer fit a mod's role are pinned
       at exactly 1.0 (no effect); the ware structure is fixed in data, so
       they cannot be removed with attribute replaces.
     - Optional pool entries are pinned too; which pool bonuses appear is
       engine-side selection RNG that game data cannot remove.
     Scenario mods (mod_weapon_damage_fleet_battle_1 - already fixed-value
     in vanilla), the engine/ship/shield sections and weights are
     untouched. -->
<diff>
  <!-- ============================ BASIC (quality 1) ==================== -->

  <!-- Piercer = DAMAGE. Pure damage, no secondaries: delivers its buff on
       EVERY weapon; the benchmark the combos are measured against. -->
  <replace sel="/equipmentmods/weapon/damage[@ware='mod_weapon_damage_01_mk1']/@min">1.1667</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/weapon/damage[@ware='mod_weapon_damage_01_mk1']/@max">1.1667</replace><!-- vanilla 1.2 -->

  <!-- Tramontane = COOLING. Pure coolrate: big on heat-limited guns,
       nothing on the heatless majority. -->
  <replace sel="/equipmentmods/weapon/cooling[@ware='mod_weapon_cooling_01_mk1']/@min">1.75</replace><!-- vanilla 1.048 -->
  <replace sel="/equipmentmods/weapon/cooling[@ware='mod_weapon_cooling_01_mk1']/@max">1.75</replace><!-- vanilla 1.216 -->

  <!-- Cowboy = RELOAD. Pure fire rate: full value on heatless and clip
       weapons, taxed on heat weapons (faster firing = more heat). As the
       single-stat mod it must out-rate the damage+reload pair (Stabber)
       on its home turf, so its headline is higher than a damage single's -
       reload is situational where damage is universal. Vanilla 0.682-2
       crossed 1.0 and was a reroll lottery. -->
  <replace sel="/equipmentmods/weapon/reload[@ware='mod_weapon_reload_01_mk1']/@min">1.25</replace><!-- vanilla 0.682 -->
  <replace sel="/equipmentmods/weapon/reload[@ware='mod_weapon_reload_01_mk1']/@max">1.25</replace><!-- vanilla 2 -->

  <!-- Jumper: the charge-cannon mod: x0.58 charge time plus a +10%
       damage rider (added block) - best Basic pick on the whole charge
       family (KHA Ravager/Obliterator, Ray Ion Projector, Erlking, ...),
       utility-grade +10% elsewhere. -->
  <replace sel="/equipmentmods/weapon/chargetime[@ware='mod_weapon_chargetime_01_mk1']/@min">0.58</replace><!-- vanilla 0.8 -->
  <replace sel="/equipmentmods/weapon/chargetime[@ware='mod_weapon_chargetime_01_mk1']/@max">0.58</replace><!-- vanilla 0.95 -->
  <add sel="/equipmentmods/weapon/chargetime[@ware='mod_weapon_chargetime_01_mk1']">
    <bonus chance="1.0" max="1">
      <damage min="1.1" max="1.1"/>
    </bonus>
  </add>

  <!-- Basic utility mods: primaries pinned at their vanilla best roll
       (max already equals the pin, so only min changes), plus a flat
       +10% damage rider (added forced bonus block - no vanilla
       counterpart) so picking a utility niche costs ~6% DPS vs the
       dedicated damage/cooling bucket (+16.67%) instead of all of it.
       Digger (mining) is the one exception - yield is its draw and a
       damage rider on a mining mod re-opens the combat-cheat door.
       Niches:
       Dispatcher = velocity (projectiles arrive faster, range nearly
       unchanged: 1.25 x 0.84 = +5%), Endurance = reach (+21% range
       = 1.1 speed x 1.1 lifetime, flight character unchanged),
       Lens = beam reach (+21%, matching Endurance's range gain),
       Gimbal = turret tracking, Gum = sticky weapons,
       Intruder = anti-surface-element work. -->

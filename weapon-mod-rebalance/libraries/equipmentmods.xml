<!-- Pokey's Weapon Mod Rebalance - weapon section of equipmentmods.xml only.

     Design (docs/weapon-mod-rebalance-design.md, scorecard in
     docs/weapon-mod-rebalance-v1.md):
     - NO RNG: every roll range is pinned (min = max) - what you craft is
       what you get, rerolling is pointless.
     - BASIC TIER TESTBED - equal power at the touchpoint, different
       currencies: the six Basic DPS mods are all calibrated to +16.67%
       full-cycle DPS on the S Bolt Repeater Mk1 (the median heat weapon,
       38.4% cooldown cycle). Pure damage delivers it on every weapon;
       cooling-heavy mixes under-deliver on cool-running guns and
       over-deliver on hot ones; reload-carrying mixes tilt toward
       reload-RATE weapons (multipliers are literal, so their reload buff
       is a malus on reload-TIME weapons). Cooling-primary mods prefer
       cooling over direct damage; damage-primary mods the reverse.
       Enhanced/Exceptional keep interim pinned values (tier-pinned
       damage, capped cooling) until this pattern is proven and extended
       to them.
     - Secondary bundles stay worth <16% cycle DPS on any weapon.
     - Structural malus slots that no longer fit a mod's role are pinned
       at exactly 1.0 (no effect); the ware structure is fixed in data, so
       they cannot be removed with attribute replaces.
     - Optional pool entries are pinned too; which pool bonuses appear is
       engine-side selection RNG that game data cannot remove.
     Scenario mods (mod_weapon_damage_fleet_battle_1 - already fixed-value
     in vanilla), the engine/ship/shield sections and weights are
     untouched. -->
<diff>
  <!-- ============================ BASIC (quality 1) ==================== -->

  <!-- Piercer: pure damage - delivers the Basic +16.67% on EVERY weapon;
       the benchmark the mixes are measured against. -->
  <replace sel="/equipmentmods/weapon/damage[@ware='mod_weapon_damage_01_mk1']/@min">1.1667</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/weapon/damage[@ware='mod_weapon_damage_01_mk1']/@max">1.1667</replace><!-- vanilla 1.2 -->

  <!-- Tramontane: pure coolrate = +16.67% on the touchpoint; less on
       cool-running guns, +50% on the Ion Pulse Railgun; nothing on the
       137 heatless weapons. -->
  <replace sel="/equipmentmods/weapon/cooling[@ware='mod_weapon_cooling_01_mk1']/@min">1.83</replace><!-- vanilla 1.048 -->
  <replace sel="/equipmentmods/weapon/cooling[@ware='mod_weapon_cooling_01_mk1']/@max">1.83</replace><!-- vanilla 1.216 -->

  <!-- Cowboy: +20% fire rate on reload-RATE weapons (on reload-TIME
       weapons the same multiplier is -16.7% - the soft gate) plus a
       tempered +5% damage rider (added block): clip weapons only get
       partial value from fire rate (the clip reload is fixed), so the
       rider tips Cowboy over Piercer exactly on the clip weapons where
       reload contributes most - the burst-weapon specialist. Vanilla
       0.682-2 crossed 1.0 and was a reroll lottery. -->
  <replace sel="/equipmentmods/weapon/reload[@ware='mod_weapon_reload_01_mk1']/@min">1.2</replace><!-- vanilla 0.682 -->
  <replace sel="/equipmentmods/weapon/reload[@ware='mod_weapon_reload_01_mk1']/@max">1.2</replace><!-- vanilla 2 -->
  <add sel="/equipmentmods/weapon/reload[@ware='mod_weapon_reload_01_mk1']">
    <bonus chance="1.0" max="1">
      <damage min="1.05" max="1.05"/>
    </bonus>
  </add>

  <!-- Jumper: the charge-cannon mod: x0.58 charge time plus a +10%
       damage rider (added block) - best Basic pick on the whole charge
       family (KHA Ravager/Obliterator, Ray Ion Projector, Erlking, ...),
       utility-grade +10% elsewhere. -->
  <replace sel="/equipmentmods/weapon/chargetime[@ware='mod_weapon_chargetime_01_mk1']/@min">0.58</replace><!-- vanilla 0.8 -->
  <replace sel="/equipmentmods/weapon/chargetime[@ware='mod_weapon_chargetime_01_mk1']/@max">0.58</replace><!-- vanilla 0.95 -->

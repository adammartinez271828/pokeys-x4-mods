<?xml version="1.0" encoding="utf-8"?>
<!-- Pokey's Hull Mod Rebalance - ship section of equipmentmods.xml only.
     DRAFT for review.

     The <ship> section is the most heterogeneous (~11 stat families). Four
     archetypes span all three tiers, plus Basic-only utility picks:

       Archetype  Feel                     Levers                Carriers (Q1/Q2/Q3)
       Racer      mobility (accel+speed)   mass + drag           mass_mk1/mk2/mk3
       Tank       durability + support     maxhull + radar +     maxhull_mk1 /
                  (loaded logistics)       ALL capacity          drag_mk2 / hidecargo
       Ghost      stealth (+ hide cargo)   radarcloak            radarcloak_mk1/mk2/mk3
       Explorer   hazard resistance        regiondamage          regiondamage_mk1/mk2/mk3
       Recon      sensors (Basic; folds)   radarrange            radarrange_mk1
       Loadout    countermeasures (Basic)  countermeasurecap     countermeasure_mk1
       Smuggler   hide cargo (Basic)       hidecargo+deployable  deployable_mk1

     - MAXHULL is the always-good stat (hull analog of damage / forward speed /
       shield capacity): it scales each tier and rides on EVERY Enhanced (+10%)
       and Exceptional (+20%) mod. Tank is built on it.
     - CAPACITY mods are FLAT (+N consumables; base ~8 on S to ~20 on L), so we
       can be generous. Tank is the loaded logistics mod: it folds in Recon +
       Loadout and carries ALL capacity types, scaling per tier.
     - Cargo hiding lives on the Smuggler (Basic), Shroud (Exc Ghost) and Mirage
       (Exc Tank).
     - No RNG. Ghost keeps a mild stealth-costs-radar cost at Basic (flips to a
       radar buff at Exceptional). Explorer's vanilla hull malus dropped; at
       Exceptional it is total hazard immunity.
     - Degenerate (Basic only, parked): the redundant drag ware + missile/unit
       capacity (folded into Tank above Basic anyway). -->
<diff>

  <!-- ============================ BASIC (quality 1) ==================== -->

  <!-- Racer = mass: -10% mass (accel) + -10% drag (top speed). -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk1']/@min">0.9</replace><!-- vanilla 0.833 -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk1']/@max">0.9</replace><!-- vanilla 0.953 -->
  <add sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk1']"><bonus chance="1.0" max="1"><drag min="0.9" max="0.9"/></bonus></add>

  <!-- Tank = maxhull: +20% hull. -->
  <replace sel="/equipmentmods/ship/maxhull[@ware='mod_ship_maxhull_01_mk1']/@min">1.2</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/ship/maxhull[@ware='mod_ship_maxhull_01_mk1']/@max">1.2</replace><!-- vanilla 1.2 -->

  <!-- Recon = radar range: +33% (folds into Tank above Basic). -->
  <replace sel="/equipmentmods/ship/radarrange[@ware='mod_ship_radarrange_01_mk1']/@min">1.333</replace><!-- vanilla 1.05 -->
  <replace sel="/equipmentmods/ship/radarrange[@ware='mod_ship_radarrange_01_mk1']/@max">1.333</replace><!-- vanilla 1.2 -->

  <!-- Loadout = Barrage: the one-stop-shop capacity mod, +4 to ALL of
       CM/deploy/missile/unit (folds into Tank above Basic). -->
  <replace sel="/equipmentmods/ship/countermeasurecapacity[@ware='mod_ship_countermeasurecapacity_01_mk1']/@min">4</replace><!-- vanilla 1 -->
  <replace sel="/equipmentmods/ship/countermeasurecapacity[@ware='mod_ship_countermeasurecapacity_01_mk1']/@max">4</replace><!-- vanilla 4 -->
  <add sel="/equipmentmods/ship/countermeasurecapacity[@ware='mod_ship_countermeasurecapacity_01_mk1']"><bonus chance="1.0" max="3"><deployablecapacity min="4" max="4"/><missilecapacity min="4" max="4"/><unitcapacity min="4" max="4"/></bonus></add>

  <!-- Smuggler = Rack: pure cargo shielder (hide cargo, no deployables). -->
  <replace sel="/equipmentmods/ship/deployablecapacity[@ware='mod_ship_deployablecapacity_01_mk1']/@min">0</replace><!-- vanilla 1: no deployables -->
  <replace sel="/equipmentmods/ship/deployablecapacity[@ware='mod_ship_deployablecapacity_01_mk1']/@max">0</replace>
  <add sel="/equipmentmods/ship/deployablecapacity[@ware='mod_ship_deployablecapacity_01_mk1']"><bonus chance="1.0" max="1"><hidecargochance min="1.0" max="1.0"/></bonus></add>

  <!-- Ghost = radarcloak: -0.35 signature, mild honest radar cost. -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk1']/@min">-0.35</replace><!-- vanilla -0.45 -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk1']/@max">-0.35</replace><!-- vanilla -0.3 -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk1']/bonus/radarrange/@min">0.85</replace><!-- vanilla 0.55 -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk1']/bonus/radarrange/@max">0.85</replace><!-- vanilla 0.7 -->

  <!-- Explorer = Grit: -60% hazard damage. Vanilla hull malus dropped. -->
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk1']/@min">0.4</replace><!-- vanilla 0.6 -->
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk1']/@max">0.4</replace><!-- vanilla 0.9 -->
  <remove sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk1']/bonus"/><!-- drop maxhull malus -->

  <!-- ---- Basic degenerate (parked; folded into Tank above Basic) ---- -->
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk1']/@min">0.97</replace><!-- redundant with Racer -->
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk1']/@max">0.97</replace>
  <replace sel="/equipmentmods/ship/missilecapacity[@ware='mod_ship_missilecapacity_01_mk1']/@min">3</replace>
  <replace sel="/equipmentmods/ship/missilecapacity[@ware='mod_ship_missilecapacity_01_mk1']/@max">3</replace>
  <replace sel="/equipmentmods/ship/unitcapacity[@ware='mod_ship_unitcapacity_01_mk1']/@min">3</replace>
  <replace sel="/equipmentmods/ship/unitcapacity[@ware='mod_ship_unitcapacity_01_mk1']/@max">3</replace>

  <!-- ========================= ENHANCED (quality 2) =================== -->
  <!-- Every mod gains a +10% maxhull sweetener. -->

  <!-- Racer = mass: -15% mass + -15% drag + hull. -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/@min">0.85</replace><!-- vanilla 0.833 -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/@max">0.85</replace><!-- vanilla 0.909 -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/@max">2</replace>
  <remove sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/radarrange"/>
  <remove sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/countermeasurecapacity"/>
  <remove sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/deployablecapacity"/>
  <remove sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/missilecapacity"/>
  <remove sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/unitcapacity"/>
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/maxhull/@min">1.1</replace>
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus/maxhull/@max">1.1</replace>
  <add sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk2']/bonus"><drag min="0.85" max="0.85"/></add>

  <!-- Tank = drag ware repurposed into loaded logistics: hull + radar + ALL
       capacity. NO drag reduction (token neutral). Pool -> force all 6. -->
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/@min">1.0</replace><!-- neutral: Tank is not a Racer -->
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/@max">1.0</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/@max">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/maxhull/@min">1.4</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/maxhull/@max">1.4</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/radarrange/@min">1.667</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/radarrange/@max">1.667</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/countermeasurecapacity/@min">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/countermeasurecapacity/@max">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/deployablecapacity/@min">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/deployablecapacity/@max">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/missilecapacity/@min">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/missilecapacity/@max">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/unitcapacity/@min">6</replace>
  <replace sel="/equipmentmods/ship/drag[@ware='mod_ship_drag_01_mk2']/bonus/unitcapacity/@max">6</replace>

  <!-- Ghost = radarcloak: -0.5 signature + hull. -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk2']/@min">-0.5</replace><!-- vanilla -0.35 -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk2']/@max">-0.5</replace><!-- vanilla -0.1 -->
  <add sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk2']"><bonus chance="1.0" max="1"><maxhull min="1.1" max="1.1"/></bonus></add>

  <!-- Explorer = Mettle: -80% hazard + hull + hide cargo (Smuggler folds in). -->
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk2']/@min">0.2</replace><!-- vanilla 0.4 -->
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk2']/@max">0.2</replace><!-- vanilla 0.65 -->
  <add sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk2']"><bonus chance="1.0" max="2"><maxhull min="1.1" max="1.1"/><hidecargochance min="1.0" max="1.0"/></bonus></add>

  <!-- ======================= EXCEPTIONAL (quality 3) ================== -->
  <!-- Every mod gains a +20% maxhull sweetener. -->

  <!-- Racer = mass (speed demon): -20% mass + -20% drag + hull. -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk3']/@min">0.8</replace><!-- vanilla 0.769 -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk3']/@max">0.8</replace><!-- vanilla 0.909 -->
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk3']/bonus/@max">2</replace>
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk3']/bonus/drag/@min">0.8</replace>
  <replace sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk3']/bonus/drag/@max">0.8</replace>
  <add sel="/equipmentmods/ship/mass[@ware='mod_ship_mass_01_mk3']/bonus"><maxhull min="1.2" max="1.2"/></add>

  <!-- Ghost = Shroud: -0.7 signature + radar buff (+33%) + hull + a little
       mobility (fast scout). -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/@min">-0.7</replace><!-- vanilla -0.8 -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/@max">-0.7</replace><!-- vanilla -0.4 -->
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/bonus/@max">4</replace>
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/bonus/radarrange/@min">1.333</replace>
  <replace sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/bonus/radarrange/@max">1.333</replace>
  <add sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/bonus"><maxhull min="1.2" max="1.2"/></add>
  <add sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/bonus"><mass min="0.95" max="0.95"/></add>
  <add sel="/equipmentmods/ship/radarcloak[@ware='mod_ship_radarcloak_01_mk3']/bonus"><drag min="0.95" max="0.95"/></add>

  <!-- Explorer = Tenacity: TOTAL hazard immunity + hull + hide cargo. -->
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/@min">0.0</replace><!-- vanilla 1.0 -->
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/@max">0.0</replace>
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/bonus/@max">4</replace>
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/bonus/maxhull/@min">1.2</replace>
  <replace sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/bonus/maxhull/@max">1.2</replace>
  <add sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/bonus"><hidecargochance min="1.0" max="1.0"/></add>
  <add sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/bonus"><mass min="0.95" max="0.95"/></add>
  <add sel="/equipmentmods/ship/regiondamage[@ware='mod_ship_regiondamage_01_mk3']/bonus"><drag min="0.95" max="0.95"/></add>

  <!-- Tank = Mirage: the support/command capstone. Big hull + strong radar
       (+100%) + heavy ALL-capacity loadout. Cargo-hide neutralised (that role
       lives on the Explorer line). -->
  <replace sel="/equipmentmods/ship/hidecargochance[@ware='mod_ship_hidecargo_01']/@min">0.0</replace><!-- no cargo hide -->
  <replace sel="/equipmentmods/ship/hidecargochance[@ware='mod_ship_hidecargo_01']/@max">0.0</replace>
  <add sel="/equipmentmods/ship/hidecargochance[@ware='mod_ship_hidecargo_01']"><bonus chance="1.0" max="6"><maxhull min="1.6" max="1.6"/><radarrange min="2.0" max="2.0"/><countermeasurecapacity min="8" max="8"/><deployablecapacity min="8" max="8"/><missilecapacity min="8" max="8"/><unitcapacity min="8" max="8"/></bonus></add>

</diff>
